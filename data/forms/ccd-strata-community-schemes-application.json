  {"label":"Respondent type","field_name":"respondent_type","type":"radio","options":["Lot owner","Owners corporation","Association","Other"],"required":true,"page":4},
  {"label":"Respondent type – other (please specify)","field_name":"respondent_type_other_specify","type":"text","required":false,"page":4},
  {"label":"Respondent first name","field_name":"respondent_first_name","type":"text","required":false,"page":4},
  {"label":"Respondent last name","field_name":"respondent_last_name","type":"text","required":false,"page":4},
  {"label":"Respondent organisation name (if applicable)","field_name":"respondent_organisation_name","type":"text","required":false,"page":4},
  {"label":"Respondent ACN/ABN","field_name":"respondent_acn_abn","type":"text","required":false,"page":4},
  {"label":"Respondent address","field_name":"respondent_address","type":"textarea","required":true,"page":4},
  {"label":"Respondent telephone","field_name":"respondent_telephone","type":"text","required":false,"page":4},
  {"label":"Respondent email","field_name":"respondent_email","type":"text","required":false,"page":4},
  {"type":"heading","text":"4. Orders and Reasons"},
  {"label":"What orders do you want? (include section numbers of the relevant Act)","field_name":"orders_requested","type":"textarea","required":true,"page":5},
