  {"label":"Applicant type – other (please specify)","field_name":"applicant_type_other_specify","type":"text","required":false,"page":2},
  {"label":"First name","field_name":"applicant_first_name","type":"text","required":true,"page":2},
  {"label":"Last name","field_name":"applicant_last_name","type":"text","required":true,"page":2},
  {"label":"Organisation name (if applicable)","field_name":"applicant_organisation_name","type":"text","required":false,"page":2},
  {"label":"ACN/ABN","field_name":"applicant_acn_abn","type":"text","required":false,"page":2},
  {"label":"Address","field_name":"applicant_address","type":"textarea","required":true,"page":2},
  {"label":"Telephone","field_name":"applicant_telephone","type":"text","required":false,"page":2},
  {"label":"Email","field_name":"applicant_email","type":"text","required":false,"page":2},
  {"label":"Are you Aboriginal or Torres Strait Islander?","field_name":"aboriginal_torres_strait_islander","type":"radio","options":["No","Prefer not to answer","Yes - Aboriginal","Yes - Torres Strait Islander","Yes - both Aboriginal and Torres Strait Islander"],"required":false,"page":3},
  {"label":"Applicant representative type","field_name":"representative_type","type":"radio","options":["Legal Practitioner","Agent","Other"],"required":false,"page":3},
  {"label":"Representative type – other (please specify)","field_name":"representative_type_other_specify","type":"text","required":false,"page":3},
  {"label":"Representative first name","field_name":"representative_first_name","type":"text","required":false,"page":3},
  {"label":"Representative last name","field_name":"representative_last_name","type":"text","required":false,"page":3},
  {"label":"Representative organisation name (if applicable)","field_name":"representative_organisation_name","type":"text","required":false,"page":3},
  {"label":"Representative ACN/ABN","field_name":"representative_acn_abn","type":"text","required":false,"page":3},
  {"label":"Representative address","field_name":"representative_address","type":"textarea","required":false,"page":3},
  {"label":"Representative telephone","field_name":"representative_telephone","type":"text","required":false,"page":3},
  {"label":"Representative email","field_name":"representative_email","type":"text","required":false,"page":3},
