[
  {"type":"instruction","text":"Complete this form to apply for orders under the Strata Schemes Management Act 2015 or Community Land Management Act 2021. Lodge your application and pay the fee with NCAT Online Services or at your nearest NCAT Registry."},
  {"type":"heading","text":"1. Dispute Details"},
  {"label":"Address of the strata or community scheme (include suburb and postcode)","field_name":"place_of_dispute","type":"textarea","required":true,"page":1},
  {"label":"Strata Scheme","field_name":"scheme_type_strata","type":"checkbox","required":false,"page":1},
  {"label":"Strata Plan (SP) number","field_name":"strata_plan_number","type":"text","required":false,"page":1},
  {"label":"Community Scheme","field_name":"scheme_type_community","type":"checkbox","required":false,"page":1},
  {"label":"Community Plan (DP) number","field_name":"community_plan_number","type":"text","required":false,"page":1},
  {"label":"Service address (owners corporation or association)","field_name":"service_address","type":"textarea","required":false,"page":1},
  {"label":"What is your dispute about? (select one only)","field_name":"dispute_type","type":"radio","options":["General orders for the settlement of a dispute","Managing agents/building managers or managing statement","Meetings of owners corporation or association","Records","Property","Penalty for breach of by laws","Penalty for breach of Tribunal orders"],"required":true,"page":1},
  {"label":"Have you tried to settle this dispute through mediation?","field_name":"mediation_attempted","type":"radio","options":["Yes","No"],"required":true,"page":1},
  {"label":"If No – what exemption are you relying on?","field_name":"mediation_exemption","type":"text","required":false,"page":1},
