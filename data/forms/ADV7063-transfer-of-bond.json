  { "type": "heading", "text": "2. Refund Details", "page": 2 },
  { "type": "instruction", "text": "Any balance held by our office will be refunded to the Tenant/s. Refunds are made by Direct Deposit. If account details are not provided your refund may be delayed.", "page": 2 },
